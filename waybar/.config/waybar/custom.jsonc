// Custom waybar config overrides
// Note: waybar include does NOT deep-merge objects, so customizations
// should be made directly in config.jsonc for nested objects like modules.
// This file can be used for top-level overrides like "height", "position", etc.
// See: https://man.archlinux.org/man/waybar.5
{
  // Example top-level overrides (uncomment to use):
  // "height": 30,
  // "position": "bottom"
}

